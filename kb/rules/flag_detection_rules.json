            "condition": {
                "field": "employment_evidence_present",
                "operator": "==",
                "value": false
            },
            "applies_to": [
                "600",
                "500"
            ]
        },
        {
            "id": "R012",
            "flag": "RF_HOME_TIES_WEAK_EMPLOYMENT",
