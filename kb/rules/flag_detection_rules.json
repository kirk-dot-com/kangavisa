                    },
                    {
                        "field": "family_ties_evidence_present",
                        "operator": "==",
                        "value": false
                    }
                ]
            },
            "applies_to": [
                "600",
                "500"
            ]
        },
        {
            "id": "R014",
            "flag": "RF_HOME_TIES_PROPERTY_MISSING",
            "description": "Assets claimed but not evidenced",
            "condition": {
                "all": [
                    {
                        "field": "assets_claimed",
