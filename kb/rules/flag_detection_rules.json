            "applies_to": [
                "600",
                "500"
            ]
        },
        {
            "id": "R015",
            "flag": "RF_INTENT_GENERIC_STATEMENT",
            "description": "Personal statement very short",
            "condition": {
                "field": "statement_word_count",
                "operator": "<",
                "value": 120
