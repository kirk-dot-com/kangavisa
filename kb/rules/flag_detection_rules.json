            "condition": {
                "field": "travel_itinerary_present",
                "operator": "==",
                "value": false
            },
            "applies_to": [
                "600"
            ]
        },
        {
            "id": "R018",
            "flag": "RF_EVIDENCE_PRIMARY_DOC_MISSING",
