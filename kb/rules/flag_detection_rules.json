        {
            "id": "R030",
            "flag": "RF_FALSE_INFORMATION_RISK",
            "description": "Multiple contradictions detected",
            "condition": {
                "field": "contradiction_count",
                "operator": ">=",
                "value": 2
            },
            "applies_to": [
                "all"
            ]
        },
        {
            "id": "R031",
            "flag": "RF_UNDISCLOSED_HISTORY",
            "description": "Previous visa refusal detected but not declared",
            "condition": {
                "all": [
                    {
                        "field": "refusal_detected",
                        "operator": "==",
                        "value": true
                    },
                    {
                        "field": "refusal_declared",
                        "operator": "==",
                        "value": false
                    }
                ]
            },
            "applies_to": [
                "600",
                "500",
                "417",
                "462",
                "189",
                "190",
