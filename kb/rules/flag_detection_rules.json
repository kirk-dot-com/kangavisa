{
    "version": "1.0",
    "engine": "kangavisa_rules_engine",
    "description": "Deterministic rules used to trigger KangaVisa readiness flags. Rules generate risk indicators, not legal determinations.",
    "rules": [
        {
            "id": "R001",
            "flag": "RF_TIMELINE_GAP",
            "description": "Large unexplained timeline gap",
            "condition": {
                "field": "largest_timeline_gap_days",
                "operator": ">",
                "value": 90
            },
            "applies_to": [
                "500",
                "485",
                "189",
                "190",
                "491",
                "600",
                "820"
            ]
        },
        {
            "id": "R002",
            "flag": "RF_TIMELINE_GAP",
            "description": "Multiple moderate timeline gaps",
            "condition": {
                "field": "timeline_gap_count_30d",
                "operator": ">=",
                "value": 2
            },
            "applies_to": [
                "500",
                "485",
                "189",
                "190",
                "491"
            ]
        },
        {
            "id": "R003",
            "flag": "RF_TIMELINE_CONFLICT",
            "description": "Conflicting employment dates",
            "condition": {
                "field": "employment_dates_consistent",
                "operator": "==",
                "value": false
            },
            "applies_to": [
                "500",
                "485",
                "189",
                "190",
                "491",
                "600"
            ]
        },
        {
            "id": "R004",
            "flag": "RF_TIMELINE_CONFLICT",
            "description": "Travel history conflicts detected",
            "condition": {
                "field": "travel_history_consistent",
                "operator": "==",
                "value": false
            },
            "applies_to": [
                "600",
                "417",
                "462",
                "500"
            ]
        },
        {
            "id": "R005",
            "flag": "RF_FINANCIAL_FUNDS_LOW",
            "description": "Available funds lower than estimated trip cost",
            "condition": {
                "left_field": "available_funds",
                "operator": "<",
                "right_field": "estimated_trip_cost"
            },
            "applies_to": [
                "600",
                "417",
                "462"
            ]
        },
        {
            "id": "R006",
            "flag": "RF_FINANCIAL_FUNDS_LOW",
            "description": "Available funds lower than estimated study cost",
            "condition": {
                "left_field": "available_funds",
                "operator": "<",
                "right_field": "estimated_study_cost"
            },
            "applies_to": [
                "500"
            ]
        },
        {
            "id": "R007",
            "flag": "RF_FINANCIAL_DEPOSITS_UNEXPLAINED",
            "description": "Large unexplained bank deposit",
            "condition": {
                "field": "largest_recent_deposit_ratio",
                "operator": ">",
                "value": 0.35
            },
            "applies_to": [
                "600",
                "500",
                "417",
                "462"
            ]
        },
        {
            "id": "R008",
            "flag": "RF_FINANCIAL_DEPOSITS_UNEXPLAINED",
            "description": "Multiple unexplained deposits",
            "condition": {
                "field": "unexplained_deposit_count",
                "operator": ">=",
                "value": 2
            },
            "applies_to": [
                "600",
                "500"
            ]
        },
        {
            "id": "R009",
            "flag": "RF_FINANCIAL_DOCS_INCOMPLETE",
            "description": "Bank statement coverage too short",
            "condition": {
                "field": "bank_statement_months",
                "operator": "<",
                "value": 3
            },
            "applies_to": [
                "600",
                "500",
                "417",
                "462",
                "485"
            ]
        },
        {
            "id": "R010",
            "flag": "RF_FINANCIAL_SPONSOR_WEAK",
            "description": "Sponsor letter missing",
            "condition": {
                "all": [
                    {
                        "field": "financial_support_sponsored",
                        "operator": "==",
                        "value": true
                    },
                    {
                        "field": "sponsor_letter_present",
                        "operator": "==",
                        "value": false
                    }
                ]
            },
            "applies_to": [
                "600",
                "500"
            ]
        },
        {
            "id": "R011",
            "flag": "RF_HOME_TIES_WEAK_EMPLOYMENT",
