                "all": [
                    {
                        "field": "currently_employed",
                        "operator": "==",
                        "value": true
                    },
                    {
                        "field": "leave_approval_present",
                        "operator": "==",
                        "value": false
                    }
                ]
            },
            "applies_to": [
                "600"
            ]
        },
        {
