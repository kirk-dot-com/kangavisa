            "condition": {
                "field": "passport_uploaded",
                "operator": "==",
                "value": false
            },
            "applies_to": [
                "600",
                "500",
                "485",
                "482",
                "820",
                "309",
                "417",
                "462",
                "189",
                "190",
                "491"
            ]
        },
        {
            "id": "R019",
            "flag": "RF_TRANSLATION_MISSING",
            "description": "Non-English document without translation",
            "condition": {
                "field": "non_english_docs_missing_translation",
                "operator": ">",
                "value": 0
            },
            "applies_to": [
                "600",
                "500",
                "485",
                "482",
                "820",
                "309"
            ]
        },
        {
            "id": "R020",
            "flag": "RF_RELATIONSHIP_EVIDENCE_WEAK",
            "description": "Insufficient partner evidence pillars",
            "condition": {
                "field": "relationship_pillars_present",
                "operator": "<",
                "value": 3
            },
            "applies_to": [
                "820",
                "801",
                "309",
                "100"
            ]
        },
        {
            "id": "R021",
            "flag": "RF_POINTS_CALCULATION_RISK",
            "description": "Claimed points exceed evidence",
            "condition": {
                "left_field": "claimed_points",
                "operator": ">",
                "right_field": "evidenced_points"
            },
            "applies_to": [
                "189",
                "190",
                "491"
            ]
        },
        {
            "id": "R022",
            "flag": "RF_SKILLS_ASSESSMENT_MISSING",
            "description": "Skills assessment missing",
            "condition": {
                "all": [
                    {
                        "field": "skills_assessment_required",
                        "operator": "==",
                        "value": true
                    },
                    {
                        "field": "skills_assessment_present",
                        "operator": "==",
                        "value": false
                    }
                ]
            },
            "applies_to": [
                "189",
                "190",
                "491"
            ]
        },
        {
            "id": "R023",
            "flag": "RF_TIMING_WINDOW_RISK",
            "description": "Application timing window short",
            "condition": {
                "field": "days_remaining_lodgement_window",
                "operator": "<",
                "value": 30
            },
            "applies_to": [
                "485",
                "417",
                "462"
            ]
        },
        {
