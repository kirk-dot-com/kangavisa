{
    "version": "1.0",
    "schema": "kangavisa_case",
    "description": "Canonical case object for KangaVisa. Represents a single visa preparation case and all related evidence, flags, scoring, and exports.",
    "entities": {
        "case": {
            "description": "Primary visa preparation case",
            "fields": {
                "case_id": "uuid",
                "user_id": "uuid",
                "visa_subclass": "string",
                "case_status": "string",
                "country_of_passport": "string",
                "lodgement_location": "string",
                "goal_summary": "string",
                "created_at": "timestamp",
                "updated_at": "timestamp",
                "last_activity_at": "timestamp"
            }
        },
        "documents": {
            "description": "Evidence documents uploaded by the applicant or sponsor",
            "fields": {
                "document_id": "uuid",
                "case_id": "uuid",
                "uploaded_by": "uuid",
                "document_type": "string",
                "file_name": "string",
                "file_storage_path": "string",
                "issuer": "string",
                "issue_date": "date",
                "valid_until": "date",
                "language": "string",
                "translation_present": "boolean",
                "created_at": "timestamp"
            }
        },
        "timeline": {
            "description": "Normalized personal timeline for the applicant",
            "fields": {
                "timeline_event_id": "uuid",
                "case_id": "uuid",
                "event_type": "string",
                "title": "string",
                "start_date": "date",
                "end_date": "date",
                "country": "string",
                "description": "string",
                "evidence_document_ids": "uuid[]"
            }
        },
        "flags": {
            "description": "Triggered readiness flags generated by rules engine",
            "fields": {
                "flag_event_id": "uuid",
                "case_id": "uuid",
                "flag_code": "string",
                "rule_id": "string",
                "severity": "string",
                "status": "string",
                "trigger_value": "json",
                "resolved_by_user": "boolean",
                "resolution_note": "string",
                "created_at": "timestamp",
                "resolved_at": "timestamp"
            }
        },
        "score": {
            "description": "Computed readiness score for the case",
            "fields": {
                "case_id": "uuid",
                "readiness_score": "number",
                "evidence_coverage": "number",
                "timeline_completeness": "number",
                "consistency_score": "number",
                "risk_indicator_score": "number",
                "unresolved_flags_count": "integer",
                "timeline_gap_count": "integer",
                "last_scored_at": "timestamp"
            }
        },
        "exports": {
            "description": "Generated readiness pack exports",
            "fields": {
                "export_id": "uuid",
                "case_id": "uuid",
                "export_type": "string",
                "export_version": "string",
                "file_path": "string",
                "generated_at": "timestamp",
                "generated_by": "uuid"
            }
        }
    },
    "relationships": {
        "case_to_documents": {
            "type": "one_to_many",
            "source": "case.case_id",
            "target": "documents.case_id"
        },
        "case_to_timeline": {
            "type": "one_to_many",
            "source": "case.case_id",
            "target": "timeline.case_id"
        },
        "case_to_flags": {
            "type": "one_to_many",
            "source": "case.case_id",
            "target": "flags.case_id"
        },
        "case_to_score": {
            "type": "one_to_one",
            "source": "case.case_id",
            "target": "score.case_id"
        },
        "case_to_exports": {
            "type": "one_to_many",
            "source": "case.case_id",
            "target": "exports.case_id"
        }
    },
    "enumerations": {
        "case_status": [
            "draft",
            "collecting_evidence",
            "reviewing_flags",
            "ready_for_export",
            "exported"
        ],
        "timeline_event_type": [
            "employment",
            "education",
            "residency",
            "travel",
            "relationship"
        ],
        "flag_status": [
            "unresolved",
            "resolved_by_note",
            "resolved_by_evidence"
        ],
        "flag_severity": [
            "low",
            "medium",
            "high",
            "critical"
        ],
        "export_type": [
            "readiness_pack_pdf",
            "agent_review_pack",
            "document_bundle_zip"
        ]
    }
}